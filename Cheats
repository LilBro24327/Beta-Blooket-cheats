(async () => {
    // 1. STATE SEEKER: This locates Blooket's internal game data (React State)
    const getStateNode = () => {
        try {
            const fiber = Object.values(document.querySelector('#app > div > div'));
            const owner = fiber.find(p => p?.child?._owner)?.child?._owner;
            return owner ? owner.stateNode : null;
        } catch (e) {
            console.error("Game state not found. Make sure you are in a live match!");
            return null;
        }
    };

    // 2. STYLES: Sets up the visual look of your menu
    const style = document.createElement("style");
    style.innerHTML = `
        #CheatGUI { 
            position: fixed; top: 15%; left: 15%; width: 600px; height: 400px; 
            background: #0bc2cf; border: 3px solid #333; border-radius: 12px; 
            z-index: 99999; display: flex; font-family: 'Nunito', sans-serif; overflow: hidden; 
        }
        .sidebar { width: 160px; background: #9a49aa; display: flex; flex-direction: column; }
        .tab-btn { padding: 15px; color: white; cursor: pointer; border-bottom: 1px solid #7a039d; font-weight: bold; }
        .tab-btn:hover { background: #7a039d; }
        .tab-btn.active { background: #40115f; }
        .content { flex: 1; background: #40115f; padding: 20px; color: white; overflow-y: auto; }
        .cheat-btn { 
            background: #0bc2cf; color: white; padding: 12px; margin-bottom: 10px; 
            border-radius: 8px; cursor: pointer; border: none; width: 100%; 
            font-weight: bold; text-align: center; transition: 0.2s;
        }
        .cheat-btn:hover { filter: brightness(1.1); transform: translateY(-1px); }
    `;
    document.head.appendChild(style);

    // 3. UI ELEMENTS: Building the menu container
    const gui = document.createElement("div");
    gui.id = "CheatGUI";
    const sidebar = document.createElement("div");
    sidebar.className = "sidebar";
    const content = document.createElement("div");
    content.className = "content";

    // 4. FUNCTION BUILDER: Helper to add buttons to the current tab
    const addCheatButton = (name, logic) => {
        const btn = document.createElement("div");
        btn.className = "cheat-btn";
        btn.innerText = name;
        btn.onclick = logic;
        content.append(btn);
    };

    // 5. TABS DEFINITIONS: All your cheat logic goes here
    const tabs = {
        "Gold Rush": () => {
            content.innerHTML = "<h3>Gold Rush Cheats</h3>";
            
            addCheatButton("Set Gold (Custom)", () => {
                const amount = Number(prompt("Enter gold amount:"));
                const node = getStateNode();
                if (node) node.setState({ gold: amount, gold2: amount });
            });

            addCheatButton("Chest ESP", () => {
                const node = getStateNode();
                if (node?.state?.choices) {
                    const rewards = node.state.choices.map((c, i) => `Chest ${i+1}: ${c.type}`).join("\n");
                    alert("Chest Contents:\n" + rewards);
                } else {
                    alert("Wait for chests to appear!");
                }
            });

            addCheatButton("Always Triple (Next Chest)", () => {
                const node = getStateNode();
                if (node) node.setState({ nextType: "triple" });
            });
        },
        "Global": () => {
            content.innerHTML = "<h3>Global Utilities</h3>";
            addCheatButton("Auto-Answer (Console Log Only)", () => {
                console.log("Auto-answer logic would trigger here.");
            });
        },
        "Settings": () => {
            content.innerHTML = "<h3>Menu Settings</h3>";
            addCheatButton("Close Cheat Menu", () => gui.remove());
        }
    };

    // 6. INITIALIZATION: Create the sidebar and set default tab
    Object.keys(tabs).forEach(tabName => {
        const btn = document.createElement("div");
        btn.className = "tab-btn";
        btn.innerText = tabName;
        btn.onclick = () => {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            tabs[tabName]();
        };
        sidebar.append(btn);
    });

    gui.append(sidebar, content);
    document.body.appendChild(gui);
    
    // Set default tab to Gold Rush
    sidebar.firstChild.click();

    console.log("%c Blooket Premium GUI %c Loaded Successfully.", "color: #0bc2cf; font-size: 1.5rem; font-weight: bold;", "color: #fff;");
})();
